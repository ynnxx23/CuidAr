generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id                      String                  @id @default(uuid()) @db.Uuid
  dni                     String                  @unique @db.VarChar(20)
  correoElectronico                   String                  @unique @db.VarChar(255)
  hashContrasena            String                  @map("hash_contrasena") @db.VarChar(255)
  nombre               String                  @map("nombre") @db.VarChar(100)
  apellido                String                  @map("apellido") @db.VarChar(100)
  telefono                   String?                 @db.VarChar(30)
  fechaNacimiento               DateTime?               @map("fecha_nacimiento") @db.Date
  genero                  String?                 @db.VarChar(30)
  estado                  EstadoUsuario              @default(pendienteVerificacion)
  verificadoCorreoEn         DateTime?               @map("verificado_correo_en") @db.Timestamptz(6)
  verificadoIdentidadEn      DateTime?               @map("verificado_identidad_en") @db.Timestamptz(6)
  creadoEn               DateTime                @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn               DateTime                @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  eliminadoEn               DateTime?               @map("eliminado_en") @db.Timestamptz(6)
  archivosSubidos           ArchivoMedico[]           @relation("UploadedBy")
  archivosValidados          ArchivoMedico[]           @relation("ValidatedBy")
  medico                  Medico?
  notificaciones           Notificacion[]
  paciente                 Paciente?
  perfilPersonal            PerfilPersonal?
  preferenciasNotificacion PreferenciaNotificacion?
  registrosAuditoria               RegistroAuditoria[]
  registrosConsentimiento          RegistroConsentimiento[]
  reportes                 Reporte[]
  sesiones                Sesion[]
  turnosCreados     Turno[]           @relation("CreatedBy")
  tutor                Tutor?
  usuariosRoles               UsuarioRol[]
  verificacionesIdentidad   VerificacionIdentidad[]
  identidadVerificada        VerificacionIdentidad[]  @relation("VerifiedByIdentity")

  @@index([correoElectronico])
  @@index([dni])
  @@index([estado])
  @@map("usuarios")
}

model Rol {
  id              String           @id @default(uuid()) @db.Uuid
  codigo            String           @unique @db.VarChar(60)
  nombre            String           @db.VarChar(100)
  descripcion     String?
  creadoEn       DateTime         @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn       DateTime         @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  rolesPermisos RolPermiso[]
  usuariosRoles       UsuarioRol[]

  @@map("roles")
}

model Permiso {
  id              String           @id @default(uuid()) @db.Uuid
  codigo            String           @unique @db.VarChar(120)
  nombre            String           @db.VarChar(100)
  descripcion     String?
  recurso        String           @db.VarChar(80)
  accion          String           @db.VarChar(80)
  creadoEn       DateTime         @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn       DateTime         @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  rolesPermisos RolPermiso[]

  @@map("permisos")
}

model UsuarioRol {
  id           String      @id @default(uuid()) @db.Uuid
  usuarioId       String      @map("user_id") @db.Uuid
  rolId       String      @map("role_id") @db.Uuid
  hospitalId   String?     @map("hospital_id") @db.Uuid
  departamentoId String?     @map("department_id") @db.Uuid
  creadoEn    DateTime    @default(now()) @map("creado_en") @db.Timestamptz(6)
  departamento   Departamento? @relation(fields: [departamentoId], references: [id])
  hospital     Hospital?   @relation(fields: [hospitalId], references: [id])
  rol         Rol        @relation(fields: [rolId], references: [id])
  usuario         Usuario        @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, rolId, hospitalId, departamentoId])
  @@map("usuarios_roles")
}

model RolPermiso {
  id           String     @id @default(uuid()) @db.Uuid
  rolId       String     @map("role_id") @db.Uuid
  permisoId String     @map("permission_id") @db.Uuid
  creadoEn    DateTime   @default(now()) @map("creado_en") @db.Timestamptz(6)
  permiso   Permiso @relation(fields: [permisoId], references: [id])
  rol         Rol       @relation(fields: [rolId], references: [id])

  @@unique([rolId, permisoId])
  @@map("roles_permisos")
}

model Sesion {
  id               String    @id @default(uuid()) @db.Uuid
  usuarioId           String    @map("user_id") @db.Uuid
  nombreDispositivo       String?   @map("nombre_dispositivo") @db.VarChar(100)
  soDispositivo         String?   @map("so_dispositivo") @db.VarChar(50)
  modeloDispositivo      String?   @map("modelo_dispositivo") @db.VarChar(100)
  nombreNavegador      String?   @map("nombre_navegador") @db.VarChar(100)
  direccionIp        String?   @map("direccion_ip") @db.VarChar(45)
  hashTokenActualizacion String    @map("hash_token_actualizacion") @db.VarChar(255)
  activo         Boolean   @default(true) @map("activo")
  ultimaActividadEn   DateTime? @map("ultima_actividad_en") @db.Timestamptz(6)
  creadoEn        DateTime  @default(now()) @map("creado_en") @db.Timestamptz(6)
  revocadoEn        DateTime? @map("revocado_en") @db.Timestamptz(6)
  usuario             Usuario      @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([activo])
  @@map("sesiones")
}

model VerificacionIdentidad {
  id               String             @id @default(uuid()) @db.Uuid
  usuarioId           String             @map("user_id") @db.Uuid
  tipoVerificacion String             @map("tipo_verificacion") @db.VarChar(80)
  estado           EstadoVerificacion @default(pendiente)
  datosEnviados    Json?              @map("datos_enviados")
  verificadoPor       String?            @map("verificado_por") @db.Uuid
  verificadoEn       DateTime?          @map("verificado_en") @db.Timestamptz(6)
  notas            String?
  creadoEn        DateTime           @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn        DateTime           @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  usuario             Usuario               @relation(fields: [usuarioId], references: [id])
  usuarioVerificador   Usuario?              @relation("VerifiedByIdentity", fields: [verificadoPor], references: [id])

  @@map("verificaciones_identidad")
}

model RegistroAuditoria {
  id           String   @id @default(uuid()) @db.Uuid
  actorUsuarioId  String?  @map("actor_user_id") @db.Uuid
  accion       String   @db.VarChar(120)
  tipoRecurso String   @map("resource_type") @db.VarChar(120)
  recursoId   String?  @map("resource_id") @db.Uuid
  metadatos     Json?
  direccionIp    String?  @map("direccion_ip") @db.VarChar(45)
  agenteUsuario    String?  @map("agente_usuario")
  creadoEn    DateTime @default(now()) @map("creado_en") @db.Timestamptz(6)
  actor        Usuario?    @relation(fields: [actorUsuarioId], references: [id])

  @@index([actorUsuarioId])
  @@index([tipoRecurso])
  @@index([creadoEn])
  @@map("registros_auditoria")
}

model Pais {
  id        String     @id @default(uuid()) @db.Uuid
  nombre      String     @unique @db.VarChar(100)
  codigoIso   String?    @unique @map("codigo_iso") @db.VarChar(10)
  creadoEn DateTime   @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn DateTime   @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  provincias Provincia[]

  @@map("paises")
}

model Provincia {
  id         String     @id @default(uuid()) @db.Uuid
  paisId  String     @map("country_id") @db.Uuid
  nombre       String     @db.VarChar(100)
  codigoIso    String?    @map("codigo_iso") @db.VarChar(10)
  creadoEn  DateTime   @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn  DateTime   @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  hospitales  Hospital[]
  localidades Localidad[]
  pais    Pais    @relation(fields: [paisId], references: [id])

  @@unique([paisId, nombre])
  @@map("provincias")
}

model Localidad {
  id            String         @id @default(uuid()) @db.Uuid
  provinciaId    String         @map("province_id") @db.Uuid
  nombre          String         @db.VarChar(120)
  creadoEn     DateTime       @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn     DateTime       @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  barrios Barrio[]
  hospitales     Hospital[]
  provincia      Provincia       @relation(fields: [provinciaId], references: [id])

  @@unique([provinciaId, nombre])
  @@map("localidades")
}

model Barrio {
  id         String     @id @default(uuid()) @db.Uuid
  localidadId String     @map("locality_id") @db.Uuid
  nombre       String     @db.VarChar(120)
  creadoEn  DateTime   @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn  DateTime   @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  localidad   Localidad   @relation(fields: [localidadId], references: [id])
  hospitales  Hospital[]

  @@unique([localidadId, nombre])
  @@map("barrios")
}

model Hospital {
  id                           String                        @id @default(uuid()) @db.Uuid
  nombre                         String                        @db.VarChar(200)
  tipoHospital                 TipoHospital                  @map("tipo_hospital")
  codigoInterno                 String?                       @unique @map("codigo_interno") @db.VarChar(50)
  correoElectronico                        String?                       @db.VarChar(255)
  telefono                        String?                       @db.VarChar(30)
  direccion                      String?
  provinciaId                   String                        @map("province_id") @db.Uuid
  localidadId                   String                        @map("locality_id") @db.Uuid
  barrioId               String?                       @map("neighborhood_id") @db.Uuid
  estado                       String                        @default("active") @db.VarChar(30)
  creadoEn                    DateTime                      @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn                    DateTime                      @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  eliminadoEn                    DateTime?                     @map("eliminado_en") @db.Timestamptz(6)
  archivosMedicos                 ArchivoMedico[]
  asignacionesPersonal             AsignacionPersonal[]
  bloquesHorarios                BloqueHorario[]
  consultorios              Consultorio[]
  departamentos                  Departamento[]
  diagnosticos                    Diagnostico[]
  especialidadesHospital          EspecialidadHospital[]
  eventosMedicos                EventoMedico[]
  excepcionesDisponibilidadMedico ExcepcionDisponibilidadMedico[]
  historiasClinicas               HistoriaClinica[]
  localidad                     Localidad                      @relation(fields: [localidadId], references: [id])
  barrio                 Barrio?                 @relation(fields: [barrioId], references: [id])
  provincia                     Provincia                      @relation(fields: [provinciaId], references: [id])
  hospitalesMedico              HospitalMedico[]
  informesMedicos               InformeMedico[]
  inscripcionesHospitalPaciente           InscripcionHospitalPaciente[]
  instantaneasEstadisticas          InstantaneaEstadistica[]
  notificaciones                Notificacion[]
  recetas                Receta[]
  reglasDisponibilidadMedico      ReglaDisponibilidadMedico[]
  relacionesAtencionPaciente     RelacionAtencionPaciente[]
  reportes                      Reporte[]
  sucursales                     SucursalHospital[]
  tratamientos                   Tratamiento[]
  turnos                 Turno[]
  usuariosRoles                    UsuarioRol[]

  @@index([provinciaId])
  @@index([localidadId])
  @@map("hospitales")
}

model SucursalHospital {
  id         String   @id @default(uuid()) @db.Uuid
  hospitalId String   @map("hospital_id") @db.Uuid
  nombre       String   @db.VarChar(200)
  direccion    String?
  telefono      String?  @db.VarChar(30)
  correoElectronico      String?  @db.VarChar(255)
  estado     String   @default("active") @db.VarChar(30)
  creadoEn  DateTime @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn  DateTime @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  hospital   Hospital @relation(fields: [hospitalId], references: [id])

  @@map("sucursales_hospital")
}

model Departamento {
  id                String                   @id @default(uuid()) @db.Uuid
  hospitalId        String                   @map("hospital_id") @db.Uuid
  nombre              String                   @db.VarChar(100)
  descripcion       String?
  estado            String                   @default("active") @db.VarChar(30)
  creadoEn         DateTime                 @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn         DateTime                 @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  asignacionesPersonal  AsignacionPersonal[]
  bloquesHorarios     BloqueHorario[]
  consultorios   Consultorio[]
  hospital          Hospital                 @relation(fields: [hospitalId], references: [id])
  hospitalesMedico   HospitalMedico[]
  availabilityRules ReglaDisponibilidadMedico[]
  usuariosRoles         UsuarioRol[]

  @@unique([hospitalId, nombre])
  @@map("departamentos")
}

model Consultorio {
  id            String         @id @default(uuid()) @db.Uuid
  hospitalId    String         @map("hospital_id") @db.Uuid
  departamentoId  String?        @map("department_id") @db.Uuid
  nombre          String         @db.VarChar(100)
  codigoConsultorio      String?        @map("codigo_consultorio") @db.VarChar(30)
  estado        String         @default("active") @db.VarChar(30)
  creadoEn     DateTime       @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn     DateTime       @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  bloquesHorarios BloqueHorario[]
  departamento    Departamento?    @relation(fields: [departamentoId], references: [id])
  hospital      Hospital       @relation(fields: [hospitalId], references: [id])
  turnos  Turno[]

  @@map("consultorios")
}

model Especialidad {
  id                  String              @id @default(uuid()) @db.Uuid
  nombre                String              @unique @db.VarChar(100)
  descripcion         String?
  creadoEn           DateTime            @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn           DateTime            @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  bloquesHorarios       BloqueHorario[]
  especialidadesHospital EspecialidadHospital[]
  especialidadesMedico   EspecialidadMedico[]
  turnos        Turno[]

  @@map("especialidades")
}

model EspecialidadHospital {
  id           String    @id @default(uuid()) @db.Uuid
  hospitalId   String    @map("hospital_id") @db.Uuid
  especialidadId  String    @map("specialty_id") @db.Uuid
  departamentoId String?   @map("department_id") @db.Uuid
  activo     Boolean   @default(true) @map("activo")
  creadoEn    DateTime  @default(now()) @map("creado_en") @db.Timestamptz(6)
  hospital     Hospital  @relation(fields: [hospitalId], references: [id])
  especialidad    Especialidad @relation(fields: [especialidadId], references: [id])

  @@unique([hospitalId, especialidadId])
  @@map("especialidades_hospital")
}

model Paciente {
  id                    String                      @id @default(uuid()) @db.Uuid
  usuarioId                String                      @unique @map("user_id") @db.Uuid
  tipoSangre             String?                     @map("tipo_sangre") @db.VarChar(10)
  alergias             String?
  condicionesCronicas     String?                     @map("condiciones_cronicas")
  medicacionActual     String?                     @map("medicacion_actual")
  contactoEmergenciaNombre  String?                     @map("contacto_emergencia_nombre") @db.VarChar(100)
  contactoEmergenciaTelefono String?                     @map("contacto_emergencia_telefono") @db.VarChar(30)
  notasMedicas          String?                     @map("notas_medicas")
  creadoEn             DateTime                    @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn             DateTime                    @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  archivosMedicos          ArchivoMedico[]
  diagnosticos             Diagnostico[]
  eventosMedicos         EventoMedico[]
  historiaClinica         HistoriaClinica?
  informesMedicos        InformeMedico[]
  inscripcionesHospital   InscripcionHospitalPaciente[]
  usuario                  Usuario                        @relation(fields: [usuarioId], references: [id])
  pacientesTutores      PacienteTutor[]
  recetas         Receta[]
  relacionesAtencionPaciente     RelacionAtencionPaciente[]
  tratamientos            Tratamiento[]
  turnos          Turno[]

  @@map("pacientes")
}

model Tutor {
  id                String            @id @default(uuid()) @db.Uuid
  usuarioId            String            @unique @map("user_id") @db.Uuid
  notasRelacion String?           @map("notas_relacion")
  creadoEn         DateTime          @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn         DateTime          @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  pacientesTutores  PacienteTutor[]
  usuario              Usuario              @relation(fields: [usuarioId], references: [id])

  @@map("tutores")
}

model PacienteTutor {
  id                  String             @id @default(uuid()) @db.Uuid
  pacienteId           String             @map("patient_id") @db.Uuid
  tutorUsuarioId      String             @map("guardian_user_id") @db.Uuid
  tipoRelacion    String             @map("tipo_relacion") @db.VarChar(80)
  estadoAutorizacion EstadoVerificacion @default(pendiente) @map("estado_autorizacion")
  creadoEn           DateTime           @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn           DateTime           @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  tutor            Tutor           @relation(fields: [tutorUsuarioId], references: [usuarioId])
  paciente             Paciente            @relation(fields: [pacienteId], references: [id])

  @@unique([pacienteId, tutorUsuarioId])
  @@map("pacientes_tutores")
}

model InscripcionHospitalPaciente {
  id         String   @id @default(uuid()) @db.Uuid
  pacienteId  String   @map("patient_id") @db.Uuid
  hospitalId String   @map("hospital_id") @db.Uuid
  estado     String   @default("active") @db.VarChar(30)
  creadoEn  DateTime @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn  DateTime @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  hospital   Hospital @relation(fields: [hospitalId], references: [id])
  paciente    Paciente  @relation(fields: [pacienteId], references: [id])

  @@unique([pacienteId, hospitalId])
  @@map("inscripciones_hospital_paciente")
}

model RelacionAtencionPaciente {
  id               String   @id @default(uuid()) @db.Uuid
  pacienteId        String   @map("patient_id") @db.Uuid
  medicoId         String   @map("doctor_id") @db.Uuid
  hospitalId       String   @map("hospital_id") @db.Uuid
  tipoRelacion String   @map("tipo_relacion") @db.VarChar(80)
  principal        Boolean  @default(false) @map("principal")
  creadoEn        DateTime @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn        DateTime @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  medico           Medico   @relation(fields: [medicoId], references: [id])
  hospital         Hospital @relation(fields: [hospitalId], references: [id])
  paciente          Paciente  @relation(fields: [pacienteId], references: [id])

  @@unique([pacienteId, medicoId, hospitalId])
  @@map("relaciones_atencion_paciente")
}

model PerfilPersonal {
  id          String            @id @default(uuid()) @db.Uuid
  usuarioId      String            @unique @map("user_id") @db.Uuid
  tipoPersonal   String            @map("tipo_personal") @db.VarChar(80)
  notas       String?
  creadoEn   DateTime          @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn   DateTime          @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  asignaciones AsignacionPersonal[]
  usuario        Usuario              @relation(fields: [usuarioId], references: [id])

  @@map("perfiles_personal")
}

model AsignacionPersonal {
  id             String       @id @default(uuid()) @db.Uuid
  perfilPersonalId String       @map("staff_profile_id") @db.Uuid
  hospitalId     String       @map("hospital_id") @db.Uuid
  departamentoId   String?      @map("department_id") @db.Uuid
  etiquetaRol      String       @map("etiqueta_rol") @db.VarChar(100)
  activo       Boolean      @default(true) @map("activo")
  creadoEn      DateTime     @default(now()) @map("creado_en") @db.Timestamptz(6)
  departamento     Departamento?  @relation(fields: [departamentoId], references: [id])
  hospital       Hospital     @relation(fields: [hospitalId], references: [id])
  perfilPersonal   PerfilPersonal @relation(fields: [perfilPersonalId], references: [id])

  @@map("asignaciones_personal")
}

model Medico {
  id                     String                        @id @default(uuid()) @db.Uuid
  usuarioId                 String                        @unique @map("user_id") @db.Uuid
  numeroMatricula   String                        @unique @map("numero_matricula") @db.VarChar(100)
  biografia                    String?
  estadoLaboral              EstadoLaboralMedico               @default(disponible) @map("estado_laboral")
  notas                  String?
  creadoEn              DateTime                      @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn              DateTime                      @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  bloquesHorarios          BloqueHorario[]
  diagnosticos              Diagnostico[]
  especialidades            EspecialidadMedico[]
  eventosMedicos          EventoMedico[]
  availabilityExceptions ExcepcionDisponibilidadMedico[]
  historiasClinicas         HistoriaClinica[]               @relation("PrimaryDoctor")
  hospitales              HospitalMedico[]
  informesMedicos         InformeMedico[]
  usuario                   Usuario                          @relation(fields: [usuarioId], references: [id])
  notificaciones          Notificacion[]
  recetas          Receta[]
  availabilityRules      ReglaDisponibilidadMedico[]
  relacionesAtencionPaciente      RelacionAtencionPaciente[]
  tratamientos             Tratamiento[]
  turnos           Turno[]

  @@map("medicos")
}

model EspecialidadMedico {
  id          String    @id @default(uuid()) @db.Uuid
  medicoId    String    @map("doctor_id") @db.Uuid
  especialidadId String    @map("specialty_id") @db.Uuid
  principal   Boolean   @default(false) @map("principal")
  creadoEn   DateTime  @default(now()) @map("creado_en") @db.Timestamptz(6)
  medico      Medico    @relation(fields: [medicoId], references: [id])
  especialidad   Especialidad @relation(fields: [especialidadId], references: [id])

  @@unique([medicoId, especialidadId])
  @@map("especialidades_medico")
}

model HospitalMedico {
  id           String      @id @default(uuid()) @db.Uuid
  medicoId     String      @map("doctor_id") @db.Uuid
  hospitalId   String      @map("hospital_id") @db.Uuid
  departamentoId String?     @map("department_id") @db.Uuid
  activo     Boolean     @default(true) @map("activo")
  creadoEn    DateTime    @default(now()) @map("creado_en") @db.Timestamptz(6)
  actualizadoEn    DateTime    @updatedAt @map("actualizado_en") @db.Timestamptz(6)
  departamento   Departamento? @relation(fields: [departamentoId], references: [id])
  medico       Medico      @relation(fields: [medicoId], references: [id])
  hospital     Hospital    @relation(fields: [hospitalId], references: [id])

  @@unique([medicoId, hospitalId, departamentoId])
  @@map("hospitales_medico")
}

