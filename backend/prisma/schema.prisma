  documentoLegal   DocumentoLegal @relation(fields: [documentoLegalId], references: [id])
  usuario            Usuario          @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, documentoLegalId])
  @@map("registros_consentimiento")
}

model InstantaneaEstadistica {
  id           String    @id @default(uuid()) @db.Uuid
  hospitalId   String?   @map("hospital_id") @db.Uuid
  provinciaId   String?   @map("province_id") @db.Uuid
  localidadId   String?   @map("locality_id") @db.Uuid
  fechaInstantanea DateTime  @map("fecha_instantanea") @db.Date
  datos         Json?
  creadoEn    DateTime  @default(now()) @map("creado_en") @db.Timestamptz(6)
  hospital     Hospital? @relation(fields: [hospitalId], references: [id])

  @@map("instantaneas_estadisticas")
}

model Reporte {
  id              String    @id @default(uuid()) @db.Uuid
  creadoPorUsuarioId String    @map("creado_por_usuario_id") @db.Uuid
  hospitalId      String?   @map("hospital_id") @db.Uuid
  tipoReporte      String    @map("tipo_reporte") @db.VarChar(80)
  titulo           String    @db.VarChar(200)
  descripcion     String?
  urlArchivo         String?   @map("url_archivo")
  creadoEn       DateTime  @default(now()) @map("creado_en") @db.Timestamptz(6)
  creadoPor       Usuario      @relation(fields: [creadoPorUsuarioId], references: [id])
  hospital        Hospital? @relation(fields: [hospitalId], references: [id])

  @@map("reportes")
}

